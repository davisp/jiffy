{require_min_otp_vsn, "21"}.

{port_specs, [
    {"priv/jiffy.so", [
        "c_src/jiffy.c"
    ]}
]}.

{port_env, [
    {"(linux|solaris|freebsd|netbsd|openbsd|dragonfly|darwin|gnu)",
        "CFLAGS", "$CFLAGS -Ic_src/ -g -Wall -Werror -O3 -fvisibility=hidden"}
]}.

{eunit_opts, [
    verbose
]}.
